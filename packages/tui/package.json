{
  "name": "@jsonbored/nightward-tui",
  "version": "0.0.0-development",
  "private": true,
  "description": "OpenTUI interface for Nightward scan reports.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun src/main.ts",
    "demo": "bun src/main.ts --input ../../site/public/demo/nightward-sample-scan.json",
    "test": "bun test",
    "build": "bun build src/main.ts --target bun --outdir ../../bin/tui-next",
    "compile": "bun build src/main.ts --target bun --compile --outfile ../../bin/nightward-tui",
    "sidecars": "node ../../scripts/build-opentui-sidecars.mjs"
  },
  "dependencies": {
    "@opentui/core": "0.2.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.21"
  }
}
